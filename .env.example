# Admin panel — set in .env.local locally; Vercel dashboard in production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_a_strong_password
ADMIN_SESSION_SECRET=change_me_to_a_random_string_at_least_32_chars

# Public site URL (SEO, sitemap, Open Graph) — no trailing slash
SITE_URL=https://reliablecompany.sa
NEXT_PUBLIC_SITE_URL=https://reliablecompany.sa

# CMS persistence — MongoDB Atlas (data survives redeployments)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=reliable_cms

# Masar/cPanel: leave unset (images served as compressed files, no CPU optimizer).
# Vercel: set NEXT_IMAGE_UNOPTIMIZED=0 to enable Next image optimization.
# NEXT_IMAGE_UNOPTIMIZED=1

# WhatsApp — click-to-chat uses COMPANY_PHONE by default
NEXT_PUBLIC_WHATSAPP_PHONE_NUMBER=+966563913902

# WhatsApp Cloud API (optional — notifies your team on form submissions)
WHATSAPP_PHONE_NUMBER=+966563913902
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_NOTIFY_NUMBER=

# Optional: AI translation in CMS (falls back to MyMemory API if unset)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
