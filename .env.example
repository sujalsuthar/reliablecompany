# Admin panel — set in .env.local (never commit real passwords)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_a_strong_password
ADMIN_SESSION_SECRET=change_me_to_a_random_string_at_least_32_chars

# Public site URL (SEO, sitemap, Open Graph) — no trailing slash
SITE_URL=https://engineering.reliablecompany.sa

# Node environment (set to production on cPanel / VPS)
NODE_ENV=production

# CMS persistence (Vercel production — provision KV + Blob in Vercel dashboard)
# On cPanel / VPS leave these empty — CMS uses data/cms-store.json and public/uploads/
# KV: connect Upstash Redis integration — needs URL + token (Vercel may use either name)
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Alternative names when using Upstash Redis integration directly:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Blob: from Vercel Blob store — BLOB_READ_WRITE_TOKEN is required for uploads
BLOB_READ_WRITE_TOKEN=
# Optional legacy names (Vercel may auto-inject these when Blob is linked):
# BLOB_STORE_ID=
# BLOB_WEBHOOK_PUBLIC_KEY=

# Optional: AI translation in CMS (falls back to MyMemory API if unset)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
